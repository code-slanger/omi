ANTHROPIC_API_KEY=your-api-key-here

# ── Porkbun DNS (used by Caddy for TLS certificate DNS challenge) ─────────────
# Get keys at porkbun.com → Account → API Access
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# ── Whisper (OpenAI API) ──────────────────────────────────────────────────────
# API key for OpenAI Whisper transcription (whisper-1 model)
WHISPER_TOKEN=your-openai-api-key-here

# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
DATA_DIR=/app/data

# S3 (only if STORAGE_BACKEND=s3)
S3_BUCKET=
AWS_REGION=us-east-1

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── Alchemist OS — creative writer ───────────────────────────────────────────
# Opus with adaptive thinking for best voice matching
GENERATION_MODEL=claude-opus-4-6

# ── Omi webhook ──────────────────────────────────────────────────────────────
# Ignore transcripts shorter than this (filters ambient noise)
OMI_MIN_WORDS=10

# ── Nano Claw — cognitive agent ──────────────────────────────────────────────
NANO_CLAW_MODEL=claude-haiku-4-5-20251001
# Primary user ID — all Telegram messages and vault notes use this
NANO_CLAW_USER_ID=default

# ── Obsidian vault ───────────────────────────────────────────────────────────
# Absolute path to the vault on the Pi. Leave empty to disable vault integration.
OBSIDIAN_VAULT_PATH=/app/vault

# ── Telegram bot ─────────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram → /newbot → copy token here
TELEGRAM_BOT_TOKEN=
# Chat ID to receive the daily digest. Get it from @userinfobot or send /status
# to your bot and update the field. Leave empty to disable auto-posting.
TELEGRAM_CHAT_ID=

# ── Email (SMTP — sending) ────────────────────────────────────────────────────
# Leave blank to disable the send_email tool.
# Gmail: create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com

# ── Email (IMAP — reading) ────────────────────────────────────────────────────
# Uses SMTP_USER/SMTP_PASSWORD credentials above.
# Leave IMAP_HOST empty to disable email reading in digests / agent.
# For Gmail: imap.gmail.com port 993
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── Multi-LLM providers ───────────────────────────────────────────────────────

# Google Gemini — used for long-context summarization (e.g. YouTube transcripts)
# Get API key at aistudio.google.com
GEMINI_API_KEY=

# Ollama — local model server. Start with: docker compose --profile ollama up
# Set to http://ollama:11434 when using the ollama Docker service
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# ── Calendar integration ──────────────────────────────────────────────────────

# Option A: CalDAV (read + write — Nextcloud, Radicale, Apple Calendar, etc.)
CALDAV_URL=
CALDAV_USER=
CALDAV_PASSWORD=

# Option B: iCal URL (read-only — use "Secret address in iCal format" from Google Calendar)
ICAL_URL=

# ── GitHub polling ────────────────────────────────────────────────────────────
# Optional token for private repos and higher rate limits (5000 vs 60 req/h)
GITHUB_TOKEN=

# ── Daily digest ──────────────────────────────────────────────────────────────
# Base URL for digest links posted to Telegram.
# Default: http://192.168.0.27:8000 — update if you have a domain / reverse proxy.
DIGEST_BASE_URL=http://192.168.0.27:8000

# ── Vision capture (OMI Glasses camera → Obsidian vault) ─────────────────────
# Requires OBSIDIAN_VAULT_PATH to be set. Photos from the glasses are analyzed
# with Claude Vision; readable text is saved as Markdown under Captures/.
#
# Set to false to disable vision processing of incoming photos.
VISION_CAPTURE_ENABLED=true
# Minimum confidence (0.0–1.0) required to save a capture to the vault.
# Lower = more permissive; higher = only very clear text is saved.
VISION_MIN_CONFIDENCE=0.6
# Minutes before the same text content can be saved again (deduplication).
# Prevents duplicate notes when the glasses see the same page multiple times.
VISION_DEDUP_MINUTES=5
